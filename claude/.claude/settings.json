{
  "env": {
    "API_TIMEOUT_MS": "10000000",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "DISABLE_COST_WARNINGS": "1",
    "ENABLE_STREAMING": "true",
    "MAX_MCP_OUTPUT_TOKENS": "32000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "mcp__serena__*",
      "mcp__repomix__*",
      "mcp__4_5v_mcp__*",
      "mcp__context7__*",
      "mcp__plugin_claude-mem_mcp-search__*",
      "mcp__web_reader__*",
      "Grep*",
      "Glob*",
      "Read*",
      "Read(Plan*)",
      "Plan*",
      "Search*",
      "Agent(explorer)",
      "Agent(planner)",
      "Agent(technical-architect)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git ls-files*)",
      "Bash(git rev-parse*)",
      "Bash(git rev-list*)",
      "Bash(git ls-tree*)",
      "Bash(git cat-file*)",
      "Bash(git describe*)",
      "Bash(git remote*)",
      "Bash(git stash list*)",
      "Bash(git tag -l*)",
      "Bash(git shortlog*)",
      "Bash(git whatchanged*)",
      "Bash(git blame*)",
      "Bash(git grep*)",
      "Bash(git branch --list*)",
      "Bash(git branch -a*)",
      "Bash(git branch -r*)",
      "Bash(git symbolic-ref*)",
      "Bash(git for-each-ref*)",
      "Bash(git show-ref*)",
      "Bash(git config --list*)",
      "Bash(git config --get*)",
      "Bash(grep*)",
      "Bash(rg*)",
      "Bash(find*)",
      "Bash(ls*)",
      "Bash(mkdir*)",
      "Bash(echo*)",
      "Bash(mv*)",
      "Bash(sed*)",
      "Bash(cat*)",
      "Bash(touch*)",
      "Bash(npx tsx*)",
      "Bash(npx tsc*)",
      "Bash(npm run build)",
      "Bash(npm run dev)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "opus[1m]",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-window-option -t \"$TMUX_PANE\" window-status-format '#[fg=white,bg=red] #I #W ' 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "tmux set-window-option -t \"$TMUX_PANE\" -u window-status-format 2>/dev/null || true",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "printf \"\\033[01;32m%s@%s\\033[00m:\\033[01;34m%s\\033[00m\" \"$(whoami)\" \"$(hostname -s)\" \"$(pwd)\""
  },
  "enabledPlugins": {
    "repomix-mcp@repomix": false
  },
  "sandbox": {
    "enabled": true,
    "allowUnsandboxedCommands": true,
    "network": {
      "allowedDomains": [
        "api.z.ai",
        "api.anthropic.com",
        "api.github.com",
        "github.com"
      ]
    },
    "mode": "auto-allow"
  },
  "effortLevel": "high",
  "showClearContextOnPlanAccept": true,
  "skipDangerousModePermissionPrompt": true,
  "voiceEnabled": true,
  "feedbackSurveyState": {
    "lastShownTime": 1753994647675
  },
  "skipAutoPermissionPrompt": true
}
